    <script is:inline>
      (function () {
        var prefersReducedMotion =
          typeof window.matchMedia === "function" &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        var carouselStates = {};

        function renderCarousel(state) {
          var index = state.currentIndex;

          state.slides.forEach(function (slide, slideIndex) {
            var isActive = slideIndex === index;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", String(!isActive));
          });

          state.dots.forEach(function (dot, dotIndex) {
            var isActive = dotIndex === index;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-pressed", String(isActive));
          });
        }

        function stopAutoplay(state) {
          if (state.autoplayId !== null) {
            window.clearInterval(state.autoplayId);
            state.autoplayId = null;
          }
        }

        function startAutoplay(state) {
          stopAutoplay(state);

          if (prefersReducedMotion || state.slides.length < 2) {
            return;
          }

          state.autoplayId = window.setInterval(function () {
            state.currentIndex = (state.currentIndex + 1) % state.slides.length;
            renderCarousel(state);
          }, state.interval);
        }

        function moveCarousel(id, step) {
          var state = carouselStates[id];

          if (!state) {
            return;
          }

          state.currentIndex =
            (state.currentIndex + step + state.slides.length) % state.slides.length;
          renderCarousel(state);
          startAutoplay(state);
        }

        function goToCarousel(id, index) {
          var state = carouselStates[id];

          if (!state) {
            return;
          }

          state.currentIndex = index;
          renderCarousel(state);
          startAutoplay(state);
        }

        function initCarousel(carousel) {
          var id = carousel.id;
          var slides = Array.prototype.slice.call(
            carousel.querySelectorAll("[data-carousel-slide]")
          );
          var dots = Array.prototype.slice.call(
            carousel.querySelectorAll("[data-carousel-dot]")
          );
          var interval = Number(carousel.getAttribute("data-interval") || 4200);

          if (!id || slides.length === 0) {
            return;
          }

          var state = {
            id: id,
            element: carousel,
            slides: slides,
            dots: dots,
            interval: interval,
            currentIndex: 0,
            autoplayId: null,
          };

          carouselStates[id] = state;

          carousel.addEventListener("mouseenter", function () {
            stopAutoplay(state);
          });
          carousel.addEventListener("mouseleave", function () {
            startAutoplay(state);
          });
          carousel.addEventListener("focusin", function () {
            stopAutoplay(state);
          });
          carousel.addEventListener("focusout", function () {
            window.setTimeout(function () {
              if (!carousel.contains(document.activeElement)) {
                startAutoplay(state);
              }
            }, 0);
          });

          renderCarousel(state);
          startAutoplay(state);
        }

        window.travelJournalCarouselMove = moveCarousel;
        window.travelJournalCarouselGoTo = goToCarousel;

        Array.prototype.forEach.call(document.querySelectorAll("[data-carousel]"), function (
          carousel
        ) {
          initCarousel(carousel);
        });

        document.addEventListener("visibilitychange", function () {
          Object.keys(carouselStates).forEach(function (id) {
            var state = carouselStates[id];

            if (document.hidden) {
              stopAutoplay(state);
              return;
            }

            startAutoplay(state);
          });
        });
      })();
    </script>
