---
import PandaEyeOverlay from "../components/PandaEyeOverlay.astro";
import SiteHeadIcons from "../components/SiteHeadIcons.astro";
import SiteFooter from "../components/SiteFooter.astro";

const name = "Glinder";
const phonetic = "/ˈglɪn.də/";
const bio =
  "I'm a creative. I design and develop digital experiences that feel simple, personal, and thoughtful.";
const currentWork =
  "I am currently building ideas across design and code while exploring where creativity and entrepreneurship overlap.";

const links = [
  { label: "MAIL", href: "mailto:mail@ahglinder.com" },
  { label: "YOUTUBE", href: "https://youtube.com/@justgreyish" },
  { label: "X", href: "https://x.com/@glinderrr" },
  { label: "INSTAGRAM", href: "https://instagram.com/@glinderrrr" },
];

const blogNotes = [
  {
    title: "Petty Beginnings",
    meta: "Relationships",
    value: "Jan 2026",
    href: "/petty-beginnings/",
  },
  {
    title: "Entrepreneurship: Lessons from Building Casestody x Greysole",
    meta: "Business, Strategy",
    value: "Dec 2025",
    href: "/entrepreneurship/",
  },
  {
    title: "Travel Journal: A Trip to Ethiopia + Dubai",
    meta: "Travel, Lifestyle",
    value: "Mar 2024",
    href: "/travel-journal/",
  },
  
];

const workItems = [
  {
    name: "Showcase",
    href: "https://showcaseapp.live",
    tags: [
      { label: "Screen Recording", style: "purple" },
      { label: "Dev", style: "orange" },
    ],
  },
  {
    name: "BusyOs",
    href: "https://joinbusyos.com",
    tags: [
      { label: "Dev", style: "blue" },
      { label: "POS", style: "green" },
    ],
  },
  {
    name: "Busyparade",
    href: "https://busyparade.com",
    tags: [
      { label: "Web Design", style: "orange" },
      { label: "Content", style: "purple" },
    ],
  },
  {
    name: "Ghfixer",
    href: "https://ghfixer.com",
    tags: [
      { label: "Artisans", style: "green" },
      { label: "Dev", style: "blue" },
    ],
  },
  {
    name: "Greysports",
    href: "/greysports/",
    tags: [
      { label: "Casestudy", style: "purple" },
      { label: "Design", style: "orange" },
    ],
  },
  {
    name: "Wukuada",
    href: "https://wukuada.com",
    tags: [
      { label: "Creators", style: "blue" },
    ],
  },
];

const featureCards = [
  {
    title: "Business",
    cta: "Open Page",
    href: "/business/",
    imageSrc: "/images/featured/Business.jpg",
    imageAlt: "A business feature card image.",
  },
  {
    title: "Studio",
    cta: "View Illustrations",
    href: "/studio/",
    imageSrc: "/images/featured/Studio.jpg",
    imageAlt: "A monochrome portrait wearing large over-ear headphones.",
  },
  {
    title: "Greywiththesign",
    cta: "See More",
    href: "/greywiththesign/",
    imageSrc: "/images/featured/gws.jpg",
    imageAlt: "A monochrome product card showing a bottle on a sculpted surface.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{name}</title>
    <meta name="description" content={`Portfolio of ${name}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
    />
    <SiteHeadIcons />
    <link rel="stylesheet" href="/styles/global.css" />
    <style>
      @media (max-width: 767px) {
        .site-nav-inner {
          justify-content: flex-end;
        }
      }
    </style>
  </head>

  <body>
    <div class="layout">
      <nav class="site-nav" aria-label="Primary">
        <div class="site-nav-inner">
          <a class="site-nav-link" href="/about-me/">About Me</a>
        </div>
      </nav>

      <main class="main">
        <div class="content">
          <div class="easter-egg" id="robotEgg">
            <div class="robot-wrap" id="robotWrap">
              <div class="robot-figure">
                <img
                  class="robot-base"
                  src="/images/featured/panda.png"
                  alt="A seated panda illustration"
                  width="1024"
                  height="1024"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
                <PandaEyeOverlay />
              </div>
            </div>
          </div>

          <section class="hero" id="about-me">
            <h1 class="hero-name">
              {`Hey, I'm ${name}`}
              <span class="hero-phonetic">{phonetic}</span>
            </h1>
            <p class="hero-bio">{bio}</p>
            <p class="hero-current">{currentWork}</p>

            <div class="cta-group">
              {links.map((link) => (
                <a
                  class="cta-btn"
                  href={link.href}
                  target={link.href.startsWith("mailto:") ? undefined : "_blank"}
                  rel="noreferrer"
                >
                  {link.label} ↗
                </a>
              ))}
            </div>
          </section>

          <section class="projects-section" aria-labelledby="projects-heading">
          </section>

          <section class="work-listing" aria-labelledby="work-heading">
            <div class="work-header">
              <h2 class="work-title" id="work-heading">Projects</h2>
            </div>

            <div class="work-rows">
              {workItems.map((item) => (
                <div class="work-row">
                  {item.href ? (
                    <a class="work-name work-name-link" href={item.href}>{item.name}</a>
                  ) : (
                    <span class="work-name">{item.name}</span>
                  )}
                  <div class="work-line" aria-hidden="true">
                    <span class="work-dot"></span>
                    <span class="work-dashes"></span>
                    <span class="work-dot"></span>
                  </div>
                  <div class="work-tags">
                    {item.tags.map((tag) => (
                      <span class={`work-tag work-tag-${tag.style}`}>{tag.label}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </section>

          <section class="feature-cards" aria-label="Featured visuals">
            {featureCards.map((card) => (
              <article class="feature-card">
                <img
                  class="feature-card-art"
                  src={card.imageSrc}
                  alt={card.imageAlt}
                  loading="lazy"
                  decoding="async"
                />

                <div class="feature-card-body">
                  <h3 class="feature-card-title">{card.title}</h3>
                  <a class="feature-card-cta" href={card.href}>{card.cta} ↗</a>
                </div>
              </article>
            ))}
          </section>

          <section class="notes-app" aria-labelledby="notes-heading">
            <div class="notes-header">
              <div>
                <h2 class="notes-title" id="notes-heading">Blogs</h2>
              </div>
            </div>

            <div class="notes-search" aria-hidden="true">
              <span class="notes-search-icon">⌕</span>
              <span class="notes-search-text">Search notes</span>
            </div>

            <div class="notes-group">
              <div class="notes-group-heading">
                <span>On Site</span>
                <span>{blogNotes.length}</span>
              </div>

              <div class="notes-list">
                {blogNotes.map((note) => (
                  <a class="notes-row" href={note.href}>
                    <div class="notes-row-main">
                      <span class="notes-folder-icon" aria-hidden="true">⌂</span>
                      <div class="notes-row-copy">
                        <span class="notes-row-title">{note.title}</span>
                        <span class="notes-row-meta">{note.meta}</span>
                      </div>
                    </div>

                    <div class="notes-row-side">
                      <span class="notes-row-value">{note.value}</span>
                      <span class="notes-row-arrow" aria-hidden="true">›</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </section>

        </div>
      </main>

      <SiteFooter />
    </div>

    <script is:inline>
      const egg = document.getElementById("robotEgg");
      const robot = document.getElementById("robotWrap");
      const pupils = Array.from(document.querySelectorAll("[data-pupil]"));
      const canHover = window.matchMedia("(hover: hover) and (pointer: fine)");

      if (egg && robot && pupils.length > 0) {
        const pointer = {
          x: 0,
          y: 0,
          active: false,
        };

        const state = {
          pupilX: 0,
          pupilY: 0,
          targetPupilX: 0,
          targetPupilY: 0,
          robotX: 0,
          robotY: 0,
          robotRot: 0,
          targetRobotX: 0,
          targetRobotY: 0,
          targetRobotRot: 0,
          frame: 0,
        };

        function setPupilTransform(x, y) {
          pupils.forEach((pupil) => {
            const isRightEye = pupil.dataset.pupil === "right";
            const offsetX = isRightEye ? x * 0.72 : x;
            const offsetY = isRightEye ? y * 0.88 : y;
            pupil.setAttribute(
              "transform",
              `translate(${offsetX.toFixed(2)} ${offsetY.toFixed(2)})`
            );
          });
        }

        function setRobotTransform(x, y, rot) {
          robot.style.transform =
            `translate3d(${x.toFixed(2)}px, ${y.toFixed(2)}px, 0) rotate(${rot.toFixed(2)}deg)`;
        }

        function ease(current, target, amount) {
          return current + (target - current) * amount;
        }

        function resetRobotTarget() {
          state.targetRobotX = 0;
          state.targetRobotY = 0;
          state.targetRobotRot = 0;
        }

        function resetAllTargets() {
          state.targetPupilX = 0;
          state.targetPupilY = 0;
          resetRobotTarget();
        }

        function updateTargets() {
          if (!pointer.active) {
            resetAllTargets();
            return;
          }

          const rect = robot.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dx = pointer.x - cx;
          const dy = pointer.y - cy;
          const dist = Math.hypot(dx, dy) || 1;

          const pupilReach = Math.min(dist * 0.06, 7.5);
          state.targetPupilX = (dx / dist) * pupilReach;
          state.targetPupilY = (dy / dist) * pupilReach;

          if (!egg.classList.contains("active")) {
            resetRobotTarget();
            return;
          }

          const bodyReach = Math.min(dist * 0.12, 7);
          state.targetRobotX = (dx / dist) * bodyReach;
          state.targetRobotY = (dy / dist) * bodyReach;
          state.targetRobotRot = (dx / dist) * 2.75;
        }

        function animate() {
          state.frame = 0;
          updateTargets();

          state.pupilX = ease(state.pupilX, state.targetPupilX, 0.24);
          state.pupilY = ease(state.pupilY, state.targetPupilY, 0.24);
          state.robotX = ease(state.robotX, state.targetRobotX, 0.16);
          state.robotY = ease(state.robotY, state.targetRobotY, 0.16);
          state.robotRot = ease(state.robotRot, state.targetRobotRot, 0.16);

          setPupilTransform(state.pupilX, state.pupilY);
          setRobotTransform(state.robotX, state.robotY, state.robotRot);

          const pupilSettled =
            Math.abs(state.pupilX - state.targetPupilX) < 0.01 &&
            Math.abs(state.pupilY - state.targetPupilY) < 0.01;
          const robotSettled =
            Math.abs(state.robotX - state.targetRobotX) < 0.01 &&
            Math.abs(state.robotY - state.targetRobotY) < 0.01 &&
            Math.abs(state.robotRot - state.targetRobotRot) < 0.01;

          if (pupilSettled && robotSettled) {
            state.pupilX = state.targetPupilX;
            state.pupilY = state.targetPupilY;
            state.robotX = state.targetRobotX;
            state.robotY = state.targetRobotY;
            state.robotRot = state.targetRobotRot;

            setPupilTransform(state.pupilX, state.pupilY);
            setRobotTransform(state.robotX, state.robotY, state.robotRot);
            return;
          }

          state.frame = window.requestAnimationFrame(animate);
        }

        function ensureAnimation() {
          if (state.frame) return;
          state.frame = window.requestAnimationFrame(animate);
        }

        robot.addEventListener("pointerenter", () => {
          egg.classList.add("active");
          ensureAnimation();
        });

        robot.addEventListener("pointerleave", () => {
          egg.classList.remove("active");
          resetRobotTarget();
          ensureAnimation();
        });

        document.addEventListener(
          "pointermove",
          (event) => {
            if (!canHover.matches || event.pointerType === "touch") return;

            pointer.x = event.clientX;
            pointer.y = event.clientY;
            pointer.active = true;
            ensureAnimation();
          },
          { passive: true }
        );

        window.addEventListener("blur", () => {
          egg.classList.remove("active");
          pointer.active = false;
          resetAllTargets();
          ensureAnimation();
        });

        canHover.addEventListener("change", () => {
          if (canHover.matches) return;
          egg.classList.remove("active");
          pointer.active = false;
          resetAllTargets();
          ensureAnimation();
        });
      }
    </script>

  </body>
</html>
