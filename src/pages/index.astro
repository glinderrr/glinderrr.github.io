---
// Edit the content below to personalise your site
const name       = "Glinder";
const phonetic   = "/ˈjɔːr neɪm/";
const bio        = `I'm a creative builder and an entrepreneur. Also, curious by default.`;

const links = [
  { label: "MAIL",      href: "mailto:mail@ahglinder.com" },
  { label: "YOUTUBE",   href: "https://youtube.com/@justgreyish" },
  { label: "X",         href: "https://x.com/@glinderrr" },
  { label: "INSTAGRAM", href: "https://instagram.com/@glinderrrr" },
];

const navLinks = [
  { label: "Home",  href: "/" },
  { label: "About", href: "/about" },
];

const projects = [
  {
    name: "Project One",
    href: "#",
    badges: [{ label: "Design", style: "blue" }],
  },
  {
    name: "Project Two",
    href: "#",
    badges: [{ label: "Design", style: "blue" }, { label: "Dev", style: "green" }],
  },
  {
    name: "Project Three",
    href: "#",
    badges: [{ label: "Research", style: "orange" }],
  },
  {
    name: "Project Four",
    href: "#",
    badges: [{ label: "Open Source", style: "purple" }],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{name}</title>
    <meta name="description" content={`Portfolio of ${name}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline>
      // Apply theme before paint to avoid flash
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', preferred);
      })();
    </script>
  </head>

  <body>
    <div class="layout">

      <!-- ── Sidebar ── -->
      <aside class="sidebar">
        <nav class="sidebar-nav">
          {navLinks.map(l => <a href={l.href}>{l.label}</a>)}
        </nav>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <span id="themeIcon">○</span>
        </button>
      </aside>

      <!-- ── Main ── -->
      <main class="main">
        <div class="content">

          <!-- Frog easter egg (desktop only) -->
          <div class="easter-egg" id="frogEgg">
            <div class="frog-wrap" id="frogWrap">
              <svg id="frogSvg" viewBox="0 0 160 175" width="140" height="140" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <radialGradient id="gBody" cx="38%" cy="30%" r="65%">
                    <stop offset="0%"   stop-color="#86efac"/>
                    <stop offset="55%"  stop-color="#22c55e"/>
                    <stop offset="100%" stop-color="#15803d"/>
                  </radialGradient>
                  <radialGradient id="gBump" cx="35%" cy="28%" r="65%">
                    <stop offset="0%"   stop-color="#6ee7b7"/>
                    <stop offset="100%" stop-color="#16a34a"/>
                  </radialGradient>
                  <radialGradient id="gBelly" cx="50%" cy="38%" r="58%">
                    <stop offset="0%"   stop-color="#f0fdf4"/>
                    <stop offset="100%" stop-color="#d1fae5"/>
                  </radialGradient>
                  <radialGradient id="gIris" cx="38%" cy="32%" r="62%">
                    <stop offset="0%"   stop-color="#fde68a"/>
                    <stop offset="45%"  stop-color="#d97706"/>
                    <stop offset="100%" stop-color="#92400e"/>
                  </radialGradient>
                  <radialGradient id="gEyeW" cx="40%" cy="35%" r="60%">
                    <stop offset="0%"   stop-color="#ffffff"/>
                    <stop offset="100%" stop-color="#e2e8f0"/>
                  </radialGradient>
                  <filter id="fShadow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#166534" flood-opacity="0.25"/>
                  </filter>
                  <filter id="fGlow" x="-30%" y="-30%" width="160%" height="160%">
                    <feDropShadow dx="0" dy="0" stdDeviation="3" flood-color="#4ade80" flood-opacity="0.4"/>
                  </filter>
                </defs>

                <!-- Ground shadow -->
                <ellipse cx="80" cy="172" rx="50" ry="7" fill="#000" opacity="0.08"/>

                <!-- Toes (behind body) -->
                <circle cx="28"  cy="158" r="10" fill="url(#gBody)"/>
                <circle cx="43"  cy="165" r="10" fill="url(#gBody)"/>
                <circle cx="59"  cy="163" r="10" fill="url(#gBody)"/>
                <circle cx="101" cy="163" r="10" fill="url(#gBody)"/>
                <circle cx="117" cy="165" r="10" fill="url(#gBody)"/>
                <circle cx="132" cy="158" r="10" fill="url(#gBody)"/>

                <!-- Body -->
                <ellipse cx="80" cy="118" rx="60" ry="52" fill="url(#gBody)" filter="url(#fShadow)"/>

                <!-- Belly -->
                <ellipse cx="80" cy="126" rx="40" ry="34" fill="url(#gBelly)"/>

                <!-- Eye bumps -->
                <circle cx="48"  cy="68" r="30" fill="url(#gBump)" filter="url(#fShadow)"/>
                <circle cx="112" cy="68" r="30" fill="url(#gBump)" filter="url(#fShadow)"/>

                <!-- Head bridge (connects bumps + body) -->
                <ellipse cx="80" cy="90" rx="55" ry="34" fill="url(#gBody)"/>

                <!-- Eye whites -->
                <circle cx="48"  cy="65" r="22" fill="url(#gEyeW)"/>
                <circle cx="112" cy="65" r="22" fill="url(#gEyeW)"/>

                <!-- Iris -->
                <circle cx="48"  cy="65" r="15" fill="url(#gIris)"/>
                <circle cx="112" cy="65" r="15" fill="url(#gIris)"/>

                <!-- Pupils -->
                <circle id="pupilL" cx="48"  cy="65" r="10" fill="#0f0f0f"/>
                <circle id="pupilR" cx="112" cy="65" r="10" fill="#0f0f0f"/>

                <!-- Eye rim (subtle dark ring) -->
                <circle cx="48"  cy="65" r="22" fill="none" stroke="#166534" stroke-width="1.2" opacity="0.4"/>
                <circle cx="112" cy="65" r="22" fill="none" stroke="#166534" stroke-width="1.2" opacity="0.4"/>

                <!-- Shine large -->
                <circle id="shineL"  cx="53"  cy="57" r="6"   fill="white" opacity="0.92"/>
                <circle id="shineR"  cx="117" cy="57" r="6"   fill="white" opacity="0.92"/>
                <!-- Shine small -->
                <circle id="shine2L" cx="58"  cy="63" r="2.5" fill="white" opacity="0.65"/>
                <circle id="shine2R" cx="122" cy="63" r="2.5" fill="white" opacity="0.65"/>

                <!-- Cheek blush -->
                <ellipse cx="28"  cy="108" rx="13" ry="9" fill="#fda4af" opacity="0.28"/>
                <ellipse cx="132" cy="108" rx="13" ry="9" fill="#fda4af" opacity="0.28"/>

                <!-- Nostrils -->
                <ellipse cx="71" cy="100" rx="3.5" ry="2.8" fill="#15803d" opacity="0.7"/>
                <ellipse cx="89" cy="100" rx="3.5" ry="2.8" fill="#15803d" opacity="0.7"/>

                <!-- MOUTH CLOSED -->
                <g id="mouthClosed">
                  <path d="M 57 118 Q 80 136 103 118" stroke="#15803d" stroke-width="3.5" fill="none" stroke-linecap="round"/>
                  <!-- Corner dimples -->
                  <circle cx="57"  cy="118" r="3" fill="#16a34a" opacity="0.5"/>
                  <circle cx="103" cy="118" r="3" fill="#16a34a" opacity="0.5"/>
                </g>

                <!-- MOUTH OPEN (hidden by default) -->
                <g id="mouthOpen" display="none">
                  <!-- Mouth cavity -->
                  <path d="M 57 116 Q 80 140 103 116 Q 80 148 57 116 Z" fill="#7f1d1d"/>
                  <!-- Lower jaw arc -->
                  <path d="M 57 116 Q 80 148 103 116" fill="#991b1b" stroke="#15803d" stroke-width="1.5"/>
                  <!-- Upper teeth -->
                  <rect x="63"  y="111" width="9"  height="7" rx="1.5" fill="white"/>
                  <rect x="74"  y="110" width="12" height="7" rx="1.5" fill="white"/>
                  <rect x="88"  y="111" width="9"  height="7" rx="1.5" fill="white"/>
                  <!-- Lower teeth (smaller) -->
                  <rect x="68"  y="131" width="7"  height="5" rx="1" fill="white" opacity="0.85"/>
                  <rect x="78"  y="133" width="8"  height="5" rx="1" fill="white" opacity="0.85"/>
                  <rect x="89"  y="131" width="7"  height="5" rx="1" fill="white" opacity="0.85"/>
                  <!-- Tongue slot hint -->
                  <ellipse cx="80" cy="141" rx="8" ry="4" fill="#be123c" opacity="0.6"/>
                </g>
              </svg>
            </div>
            <div class="hover-hint">
              <svg viewBox="0 0 80 50" width="80" height="50" xmlns="http://www.w3.org/2000/svg">
                <path d="M 70 10 Q 40 5 18 35" stroke="#9ca3af" stroke-width="1.5" fill="none" stroke-dasharray="4 3" stroke-linecap="round"/>
                <polygon points="12,40 22,32 24,44" fill="#9ca3af"/>
              </svg>
              <span class="hover-text">Hover me!</span>
            </div>
          </div>

          <!-- Hero -->
          <section class="hero">
            <h1 class="hero-name">
              {name}
              <span class="hero-phonetic">{phonetic}</span>
            </h1>
            <p class="hero-bio" set:html={bio} />
            <div class="cta-group">
              {links.map(l => (
                <a class="cta-btn" href={l.href} target={l.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener noreferrer">
                  {l.label} ↗
                </a>
              ))}
            </div>
          </section>

          <!-- Work -->
          <section>
            <p class="section-label">Work</p>
            <div class="project-list">
              {projects.map(p => (
                <a class="project-row" href={p.href} target="_blank" rel="noopener noreferrer">
                  <span class="project-name">{p.name}</span>
                  <hr class="project-divider" />
                  <div class="badge-group">
                    {p.badges.map(b => (
                      <span class={`badge badge-${b.style}`}>{b.label}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
          </section>

        </div>
      </main>
    </div>

    <!-- Tongue overlay (full-screen, pointer-events: none) -->
    <div id="tongueOverlay" style="position:fixed;inset:0;pointer-events:none;z-index:999;overflow:hidden;">
      <svg id="tongueSvg" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
        <path id="tonguePath" fill="none" stroke="#fb7185" stroke-linecap="round"/>
        <circle id="tongueTip" cx="0" cy="0" r="0" fill="#fb7185"/>
      </svg>
    </div>

    <script is:inline>
      // Frog — eye tracking + body follow
      const egg  = document.getElementById('frogEgg');
      const frog = document.getElementById('frogWrap');
      const svg  = document.getElementById('frogSvg');

      // Eye data: center in SVG viewBox space
      const eyes = [
        { pupil: document.getElementById('pupilL'),  shine: document.getElementById('shineL'),  shine2: document.getElementById('shine2L'),  ox: 48,  oy: 65 },
        { pupil: document.getElementById('pupilR'),  shine: document.getElementById('shineR'),  shine2: document.getElementById('shine2R'),  ox: 112, oy: 65 },
      ];

      function screenToSVG(x, y) {
        const pt = svg.createSVGPoint();
        pt.x = x; pt.y = y;
        return pt.matrixTransform(svg.getScreenCTM().inverse());
      }

      function movePupils(mx, my) {
        const sp = screenToSVG(mx, my);
        const maxMove = 5;
        eyes.forEach(({ pupil, shine, shine2, ox, oy }) => {
          const dx   = sp.x - ox;
          const dy   = sp.y - oy;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          const move = Math.min(dist * 0.25, maxMove);
          const px   = (dx / dist) * move;
          const py   = (dy / dist) * move;
          pupil.setAttribute('cx', ox + px);
          pupil.setAttribute('cy', oy + py);
          shine.setAttribute('cx',  ox + px + 5);
          shine.setAttribute('cy',  oy + py - 8);
          shine2.setAttribute('cx', ox + px + 10);
          shine2.setAttribute('cy', oy + py - 2);
        });
      }

      frog.addEventListener('mouseenter', () => egg.classList.add('active'));
      frog.addEventListener('mouseleave', () => {
        egg.classList.remove('active');
        frog.style.transform = 'translate(0px,0px) rotate(0deg)';
      });

      document.addEventListener('mousemove', (e) => {
        movePupils(e.clientX, e.clientY);
        if (!egg.classList.contains('active')) return;
        const rect = frog.getBoundingClientRect();
        const cx   = rect.left + rect.width  / 2;
        const cy   = rect.top  + rect.height / 2;
        const dx   = e.clientX - cx;
        const dy   = e.clientY - cy;
        const dist = Math.sqrt(dx*dx + dy*dy) || 1;
        const mx   = (dx / dist) * Math.min(dist * 0.35, 18);
        const my   = (dy / dist) * Math.min(dist * 0.35, 18);
        const rot  = (dx / dist) * 8;
        frog.style.transform = `translate(${mx}px,${my}px) rotate(${rot}deg)`;
      });
    </script>

    <script is:inline>
      const btn  = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');

      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        icon.textContent = theme === 'dark' ? '●' : '○';
      }

      // Sync icon on load
      applyTheme(document.documentElement.getAttribute('data-theme') || 'light');

      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
      });
    </script>

    <script is:inline>
      // Tongue animation
      (function () {
        const tonguePath = document.getElementById('tonguePath');
        const tongueTip  = document.getElementById('tongueTip');
        let animating = false;

        function svgToScreen(svgEl, x, y) {
          const pt = svgEl.createSVGPoint();
          pt.x = x; pt.y = y;
          return pt.matrixTransform(svgEl.getScreenCTM());
        }

        function animateTongue(sx, sy, tx, ty) {
          if (animating) return;
          animating = true;

          const EXTEND  = 160;
          const HOLD    = 90;
          const RETRACT = 200;
          const TOTAL   = EXTEND + HOLD + RETRACT;
          const t0 = performance.now();

          // Perpendicular curve offset so tongue arcs naturally
          const len   = Math.sqrt((tx-sx)**2 + (ty-sy)**2) || 1;
          const perpX = -(ty-sy) / len;
          const perpY =  (tx-sx) / len;
          const arc   = Math.min(len * 0.18, 40);

          function easeOut(t) { return 1 - (1-t)**3; }
          function easeIn(t)  { return t**3; }

          function frame(now) {
            const elapsed = now - t0;
            let p;

            if (elapsed < EXTEND) {
              p = easeOut(elapsed / EXTEND);
            } else if (elapsed < EXTEND + HOLD) {
              p = 1;
            } else {
              p = 1 - easeIn(Math.min((elapsed - EXTEND - HOLD) / RETRACT, 1));
            }

            const ex  = sx + (tx - sx) * p;
            const ey  = sy + (ty - sy) * p;
            const cpx = (sx + ex) / 2 + perpX * arc * Math.sin(p * Math.PI);
            const cpy = (sy + ey) / 2 + perpY * arc * Math.sin(p * Math.PI);

            tonguePath.setAttribute('d', `M ${sx} ${sy} Q ${cpx} ${cpy} ${ex} ${ey}`);
            tonguePath.setAttribute('stroke-width', 4 + p * 5);
            tongueTip.setAttribute('cx', ex);
            tongueTip.setAttribute('cy', ey);
            tongueTip.setAttribute('r',  p * 9);

            if (elapsed < TOTAL) {
              requestAnimationFrame(frame);
            } else {
              tonguePath.setAttribute('d', '');
              tongueTip.setAttribute('r', 0);
              // Close mouth
              document.getElementById('mouthOpen').setAttribute('display', 'none');
              document.getElementById('mouthClosed').setAttribute('display', '');
              animating = false;
            }
          }

          // Open mouth before tongue shoots out
          document.getElementById('mouthClosed').setAttribute('display', 'none');
          document.getElementById('mouthOpen').setAttribute('display', '');
          requestAnimationFrame(frame);
        }

        document.addEventListener('click', (e) => {
          if (e.target.closest('a, button')) return;
          const frogSvg = document.getElementById('frogSvg');
          if (!frogSvg) return;
          // Mouth center in new viewBox: ~(80, 128)
          const mouth = svgToScreen(frogSvg, 80, 128);
          animateTongue(mouth.x, mouth.y, e.clientX, e.clientY);
        });
      })();
    </script>
  </body>
</html>
