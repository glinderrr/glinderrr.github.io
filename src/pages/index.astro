---
// Edit the content below to personalise your site
const name       = "Glinder";
const phonetic   = "/ˈjɔːr neɪm/";
const bio        = `I'm a creative builder and an entrepreneur. Also, curious by default.`;

const links = [
  { label: "MAIL",      href: "mailto:mail@ahglinder.com" },
  { label: "YOUTUBE",   href: "https://youtube.com/@justgreyish" },
  { label: "X",         href: "https://x.com/@glinderrr" },
  { label: "INSTAGRAM", href: "https://instagram.com/@glinderrrr" },
];

const navLinks = [
  { label: "Home",  href: "/" },
  { label: "About", href: "/about" },
];

const projects = [
  {
    name: "Project One",
    href: "#",
    badges: [{ label: "Design", style: "blue" }],
  },
  {
    name: "Project Two",
    href: "#",
    badges: [{ label: "Design", style: "blue" }, { label: "Dev", style: "green" }],
  },
  {
    name: "Project Three",
    href: "#",
    badges: [{ label: "Research", style: "orange" }],
  },
  {
    name: "Project Four",
    href: "#",
    badges: [{ label: "Open Source", style: "purple" }],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{name}</title>
    <meta name="description" content={`Portfolio of ${name}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline>
      // Apply theme before paint to avoid flash
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', preferred);
      })();
    </script>
  </head>

  <body>
    <div class="layout">

      <!-- ── Sidebar ── -->
      <aside class="sidebar">
        <nav class="sidebar-nav">
          {navLinks.map(l => <a href={l.href}>{l.label}</a>)}
        </nav>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <span id="themeIcon">○</span>
        </button>
      </aside>

      <!-- ── Main ── -->
      <main class="main">
        <div class="content">

          <!-- Frog easter egg (desktop only) -->
          <div class="easter-egg" id="frogEgg">
            <div class="frog-wrap" id="frogWrap">
              <svg viewBox="0 0 100 95" width="90" height="90" xmlns="http://www.w3.org/2000/svg">
                <!-- Eye bumps -->
                <circle cx="31" cy="32" r="15" fill="#4ade80"/>
                <circle cx="69" cy="32" r="15" fill="#4ade80"/>
                <!-- Body -->
                <ellipse cx="50" cy="63" rx="36" ry="28" fill="#4ade80"/>
                <!-- Eye whites -->
                <circle cx="31" cy="31" r="10" fill="white"/>
                <circle cx="69" cy="31" r="10" fill="white"/>
                <!-- Pupils -->
                <circle id="pupilL" cx="31" cy="31" r="6" fill="#1a1a1a"/>
                <circle id="pupilR" cx="69" cy="31" r="6" fill="#1a1a1a"/>
                <!-- Eye shine -->
                <circle id="shineL" cx="33" cy="28" r="2.5" fill="white"/>
                <circle id="shineR" cx="71" cy="28" r="2.5" fill="white"/>
                <!-- Nostrils -->
                <circle cx="44" cy="56" r="2.2" fill="#22c55e"/>
                <circle cx="56" cy="56" r="2.2" fill="#22c55e"/>
                <!-- Smile -->
                <path d="M 37 70 Q 50 82 63 70" stroke="#22c55e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                <!-- Belly highlight -->
                <ellipse cx="50" cy="68" rx="18" ry="12" fill="#86efac" opacity="0.45"/>
              </svg>
            </div>
            <div class="hover-hint">
              <svg viewBox="0 0 80 50" width="80" height="50" xmlns="http://www.w3.org/2000/svg">
                <path d="M 70 10 Q 40 5 18 35" stroke="#9ca3af" stroke-width="1.5" fill="none" stroke-dasharray="4 3" stroke-linecap="round"/>
                <polygon points="12,40 22,32 24,44" fill="#9ca3af"/>
              </svg>
              <span class="hover-text">Hover me!</span>
            </div>
          </div>

          <!-- Hero -->
          <section class="hero">
            <h1 class="hero-name">
              {name}
              <span class="hero-phonetic">{phonetic}</span>
            </h1>
            <p class="hero-bio" set:html={bio} />
            <div class="cta-group">
              {links.map(l => (
                <a class="cta-btn" href={l.href} target={l.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener noreferrer">
                  {l.label} ↗
                </a>
              ))}
            </div>
          </section>

          <!-- Work -->
          <section>
            <p class="section-label">Work</p>
            <div class="project-list">
              {projects.map(p => (
                <a class="project-row" href={p.href} target="_blank" rel="noopener noreferrer">
                  <span class="project-name">{p.name}</span>
                  <hr class="project-divider" />
                  <div class="badge-group">
                    {p.badges.map(b => (
                      <span class={`badge badge-${b.style}`}>{b.label}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
          </section>

        </div>
      </main>
    </div>

    <script is:inline>
      // Frog mouse tracking
      const egg    = document.getElementById('frogEgg');
      const frog   = document.getElementById('frogWrap');
      const svg    = frog.querySelector('svg');
      const pupilL = document.getElementById('pupilL');
      const pupilR = document.getElementById('pupilR');
      const shineL = document.getElementById('shineL');
      const shineR = document.getElementById('shineR');

      // Eye centers in SVG viewBox coords
      const eyes = [
        { pupil: pupilL, shine: shineL, ox: 31, oy: 31 },
        { pupil: pupilR, shine: shineR, ox: 69, oy: 31 },
      ];

      function movePupils(mouseX, mouseY) {
        const svgRect = svg.getBoundingClientRect();
        const scaleX  = 100 / svgRect.width;
        const scaleY  = 95  / svgRect.height;
        const maxMove = 3.5;

        eyes.forEach(({ pupil, shine, ox, oy }) => {
          // Eye center in screen coords
          const ecx = svgRect.left + ox / scaleX;
          const ecy = svgRect.top  + oy / scaleY;
          const dx  = mouseX - ecx;
          const dy  = mouseY - ecy;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          const px  = (dx / dist) * Math.min(dist * 0.08, maxMove);
          const py  = (dy / dist) * Math.min(dist * 0.08, maxMove);
          pupil.setAttribute('cx', ox + px);
          pupil.setAttribute('cy', oy + py);
          shine.setAttribute('cx', ox + px + 2);
          shine.setAttribute('cy', oy + py - 3);
        });
      }

      frog.addEventListener('mouseenter', () => egg.classList.add('active'));
      frog.addEventListener('mouseleave', () => {
        egg.classList.remove('active');
        frog.style.transform = 'translate(0px, 0px) rotate(0deg)';
        eyes.forEach(({ pupil, shine, ox, oy }) => {
          pupil.setAttribute('cx', ox);
          pupil.setAttribute('cy', oy);
          shine.setAttribute('cx', ox + 2);
          shine.setAttribute('cy', oy - 3);
        });
      });

      document.addEventListener('mousemove', (e) => {
        movePupils(e.clientX, e.clientY);
        if (!egg.classList.contains('active')) return;
        const rect = frog.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top  + rect.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const max  = 18;
        const mx   = (dx / dist) * Math.min(dist * 0.35, max);
        const my   = (dy / dist) * Math.min(dist * 0.35, max);
        const rot  = (dx / dist) * 8;
        frog.style.transform = `translate(${mx}px, ${my}px) rotate(${rot}deg)`;
      });
    </script>

    <script is:inline>
      const btn  = document.getElementById('themeToggle');
      const icon = document.getElementById('themeIcon');

      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
        icon.textContent = theme === 'dark' ? '●' : '○';
      }

      // Sync icon on load
      applyTheme(document.documentElement.getAttribute('data-theme') || 'light');

      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        applyTheme(current === 'dark' ? 'light' : 'dark');
      });
    </script>
  </body>
</html>
