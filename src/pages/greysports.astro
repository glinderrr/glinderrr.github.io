    <script>
      (function () {
        var pill = document.getElementById("cursor-pill");
        var sections = document.querySelectorAll("[data-section-pill]");
        if (!pill || !sections.length || window.matchMedia("(hover: none)").matches) return;
        var activeLabel = "";
        function show(label) {
          activeLabel = label || "";
          pill.textContent = activeLabel;
          pill.classList.toggle("is-visible", !!activeLabel);
        }
        sections.forEach(function (s) {
          var label = s.getAttribute("data-section-pill") || "";
          s.addEventListener("mouseenter", function () {
            show(label);
          });
          s.addEventListener("mouseleave", function () {
            show("");
          });
        });
        document.addEventListener("mousemove", function (e) {
          pill.style.left = e.clientX + "px";
          pill.style.top = e.clientY + "px";
        });
      })();

      (function () {
        var wrap = document.getElementById("gs-wrap");
        if (!wrap) return;
        var lastBg = "";
        function detect() {
          try {
            var bg = window.getComputedStyle(document.body).backgroundColor;
            if (bg === lastBg) {
              requestAnimationFrame(detect);
              return;
            }
            lastBg = bg;
            var m = bg.match(/[\d.]+/g);
            if (!m) {
              requestAnimationFrame(detect);
              return;
            }
            var a = m[3] !== undefined ? parseFloat(m[3]) : 1;
            if (a === 0) {
              requestAnimationFrame(detect);
              return;
            }
            var brightness =
              (parseFloat(m[0]) * 299 + parseFloat(m[1]) * 587 + parseFloat(m[2]) * 114) / 1000;
            var isDark = brightness < 128;
            wrap.classList.toggle("dark-mode", isDark);

            var lightBg = getComputedStyle(wrap).getPropertyValue("--bg").trim() || "#FDFFF4";
            wrap.style.background = isDark ? "#101010" : lightBg;
          } catch (e) {
            // Ignore theme detection errors and keep polling.
          }
          requestAnimationFrame(detect);
        }
        requestAnimationFrame(detect);
      })();
    </script>
